{
	"version": "0.1.2",
	"name": "@mr/object-identity",
	"exports": "./lib/mod.ts",
	"nodeModulesDir": "auto",
	"tasks": {
		"build": "deno run -A scripts/build.ts"
	},
	"imports": {
		"@std/assert": "jsr:@std/assert@^1",
		"@std/path": "jsr:@std/path@^1",
		"fast-check": "npm:fast-check@^4",
		"json-stable-stringify": "npm:json-stable-stringify@^1",
		"object-hash": "npm:object-hash@^3",
		"oxc-minify": "npm:oxc-minify@^0.73",
		"oxc-transform": "npm:oxc-transform@^0.73",
		"tiny-stable-stringify": "npm:tiny-stable-stringify@^0.1"
	},
	"lock": false,
	"lint": {
		"rules": {
			"exclude": [
				"no-var",
				"prefer-const",
				"no-cond-assign",
				"no-inner-declarations",
				"no-explicit-any",
				"no-fallthrough"
			]
		}
	},
	"fmt": {
		"lineWidth": 100,
		"singleQuote": true,
		"useTabs": true
	},
	"exclude": [
		"npm",
		"coverage"
	],
	"publish": {
		"include": [
			"lib/mod.ts",
			"license",
			"readme.md"
		]
	}
}
